rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "titaniumfact97@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function isString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || isString(field, minLen, maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'displayName', 'email', 'photoURL', 'bloodGroup', 'role', 'createdAt']) &&
             isString('uid', 1, 128) &&
             isString('displayName', 1, 100) &&
             isString('email', 5, 100) &&
             isOptionalString('photoURL', 0, 500) &&
             isOptionalString('bloodGroup', 0, 10) &&
             request.resource.data.role in ['user', 'admin'] &&
             request.resource.data.createdAt is timestamp;
    }
    
    function isValidBloodRequest() {
      return hasOnlyAllowedFields(['requesterId', 'requesterName', 'patientCondition', 'bloodGroup', 'amount', 'hemoglobin', 'donationDate', 'donationTime', 'hospital', 'district', 'upazila', 'address', 'urgency', 'contactName', 'contactPhone', 'notes', 'status', 'donorId', 'donorName', 'createdAt']) &&
             isString('requesterId', 1, 128) &&
             isString('requesterName', 1, 100) &&
             isString('patientCondition', 1, 500) &&
             isString('bloodGroup', 1, 10) &&
             request.resource.data.amount is number && request.resource.data.amount > 0 &&
             isOptionalString('hemoglobin', 0, 50) &&
             isString('donationDate', 1, 50) &&
             isOptionalString('donationTime', 0, 50) &&
             isString('hospital', 1, 200) &&
             isString('district', 1, 100) &&
             isString('upazila', 1, 100) &&
             isOptionalString('address', 0, 500) &&
             request.resource.data.urgency in ['Emergency', 'Urgent', 'Normal'] &&
             isString('contactName', 1, 100) &&
             isString('contactPhone', 1, 50) &&
             isOptionalString('notes', 0, 1000) &&
             request.resource.data.status in ['pending', 'accepted', 'donated', 'approved', 'rejected'] &&
             isOptionalString('donorId', 0, 128) &&
             isOptionalString('donorName', 0, 100) &&
             request.resource.data.createdAt is timestamp;
    }
    
    function isValidNotification() {
      return hasOnlyAllowedFields(['userId', 'title', 'body', 'read', 'createdAt']) &&
             isString('userId', 1, 128) &&
             isString('title', 1, 200) &&
             isString('body', 1, 1000) &&
             request.resource.data.read is bool &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && 
                    (
                      (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.uid == resource.data.uid) || 
                      isAdmin()
                    );
    }
    
    match /bloodRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBloodRequest() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAuthenticated() && isValidBloodRequest() && request.resource.data.requesterId == resource.data.requesterId &&
                    (
                      isOwner(resource.data.requesterId) || // Requester can update
                      (request.resource.data.status in ['accepted', 'donated'] && request.resource.data.donorId == request.auth.uid) || // Donor can accept/donate
                      (resource.data.status == 'pending' && request.resource.data.status == 'accepted' && request.resource.data.donorId == request.auth.uid) || // Donor can accept
                      isAdmin()
                    );
      allow delete: if isAdmin() || isOwner(resource.data.requesterId);
    }
    
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidNotification();
      allow update: if isOwner(resource.data.userId) && isValidNotification() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
