rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - bloodGroup: string (optional, enum: A+, A-, B+, B-, AB+, AB-, O+, O-)
    //   - location: string (optional)
    //   - phone: string (optional)
    //   - isProfileComplete: boolean (required)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: blood_requests
    // Document ID: {requestId}
    // Fields:
    //   - requesterUid: string (required, immutable)
    //   - requesterName: string (required)
    //   - requesterPhoto: string (optional)
    //   - patientIssue: string (required)
    //   - bloodGroup: string (required, enum: A+, A-, B+, B-, AB+, AB-, O+, O-)
    //   - amount: string (required)
    //   - date: string (required)
    //   - location: string (required)
    //   - contact: string (required)
    //   - urgency: string (required, enum: High, Medium, Low)
    //   - coordinates: map (optional, lat: number, lng: number)
    //   - status: string (required, enum: pending, fulfilled)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function requesterUidUnchanged() {
      return !('requesterUid' in request.resource.data) || request.resource.data.requesterUid == request.auth.uid;
    }
    
    function requesterUidNotModified() {
      return !('requesterUid' in request.resource.data) || request.resource.data.requesterUid == resource.data.requesterUid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidEmail(email) {
      return email is string && email.matches("^.+@.+\\..+$");
    }

    function isValidBloodGroup(bg) {
      return bg in ['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'];
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      let hasRequired = hasRequiredFields(['uid', 'displayName', 'email', 'isProfileComplete', 'createdAt', 'updatedAt']);
      let validTypes = data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
                       data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
                       isValidEmail(data.email) &&
                       data.isProfileComplete is bool &&
                       data.createdAt is timestamp &&
                       data.updatedAt is timestamp;
      let validOptionals = isValidOptionalString('photoURL', 0, 2000) &&
                           isValidOptionalString('location', 0, 200) &&
                           isValidOptionalString('phone', 0, 20) &&
                           (!( 'bloodGroup' in data ) || isValidBloodGroup(data.bloodGroup)) &&
                           (!( 'eligibilityData' in data ) || data.eligibilityData is map) &&
                           (!( 'lastReadNotifications' in data ) || data.lastReadNotifications is timestamp);
      return hasRequired && validTypes && validOptionals;
    }

    function isValidBloodRequest(data) {
      let hasRequired = hasRequiredFields(['requesterUid', 'requesterName', 'patientIssue', 'bloodGroup', 'amount', 'date', 'location', 'contact', 'urgency', 'status', 'createdAt', 'updatedAt']);
      let validTypes = data.requesterUid is string && data.requesterUid.size() > 0 && data.requesterUid.size() < 100 &&
                       data.requesterName is string && data.requesterName.size() > 0 && data.requesterName.size() < 100 &&
                       data.patientIssue is string && data.patientIssue.size() > 0 && data.patientIssue.size() < 500 &&
                       isValidBloodGroup(data.bloodGroup) &&
                       data.amount is string && data.amount.size() > 0 && data.amount.size() < 100 &&
                       data.date is string && data.date.size() > 0 && data.date.size() < 100 &&
                       data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
                       data.contact is string && data.contact.size() > 0 && data.contact.size() < 100 &&
                       data.urgency in ['High', 'Medium', 'Low'] &&
                       data.status in ['open', 'pending', 'fulfilled'] &&
                       data.createdAt is timestamp &&
                       data.updatedAt is timestamp;
      let validOptionals = isValidOptionalString('requesterPhoto', 0, 1000) &&
                           (!('coordinates' in data) || (data.coordinates is map && data.coordinates.lat is number && data.coordinates.lng is number));
      return hasRequired && validTypes && validOptionals;
    }

    function isValidDonor(data) {
      let hasRequired = hasRequiredFields(['uid', 'displayName', 'bloodGroup', 'location', 'isAvailable', 'createdAt', 'updatedAt']);
      let validTypes = data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
                       data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
                       isValidBloodGroup(data.bloodGroup) &&
                       data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
                       data.isAvailable is bool &&
                       data.createdAt is timestamp &&
                       data.updatedAt is timestamp;
      let validOptionals = isValidOptionalString('photoURL', 0, 2000) &&
                           isValidOptionalString('lastDonationDate', 0, 100);
      return hasRequired && validTypes && validOptionals;
    }

    function isValidChat(data) {
      let hasRequired = hasRequiredFields(['participants', 'participantNames', 'participantPhotos', 'createdAt', 'updatedAt']);
      let validTypes = data.participants is list && data.participants.size() == 2 &&
                       data.participantNames is map &&
                       data.participantPhotos is map &&
                       data.createdAt is timestamp &&
                       data.updatedAt is timestamp;
      let validOptionals = (!('lastMessage' in data) || data.lastMessage is string) &&
                           (!('lastMessageTime' in data) || data.lastMessageTime is timestamp) &&
                           (!('lastMessageSenderId' in data) || data.lastMessageSenderId is string) &&
                           (!('lastRead' in data) || data.lastRead is map);
      return hasRequired && validTypes && validOptionals;
    }

    function isValidMessage(data) {
      let hasRequired = hasRequiredFields(['senderId', 'text', 'createdAt']);
      let validTypes = data.senderId is string && data.senderId.size() > 0 && data.senderId.size() < 100 &&
                       data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
                       data.createdAt is timestamp;
      return hasRequired && validTypes;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read and write their own profile to protect PII
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false; // Do not allow deletion for now
    }

    match /donors/{donorId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(donorId) && isValidDonor(request.resource.data) && uidUnchanged();
      allow update: if isOwner(donorId) && isValidDonor(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(donorId);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderId == request.auth.uid && isValidMessage(request.resource.data);
        allow update, delete: if false;
      }
    }

    match /bloodRequests/{requestId} {
      // Anyone authenticated can read blood requests
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.requesterUid) && isValidBloodRequest(request.resource.data) && requesterUidUnchanged();
      allow update: if isAuthenticated() && isOwner(resource.data.requesterUid) && isValidBloodRequest(request.resource.data) && requesterUidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isOwner(resource.data.requesterUid);
    }
  }
}
